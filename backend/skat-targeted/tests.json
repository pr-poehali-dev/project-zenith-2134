  "cors_preflight": {
    "name": "CORS preflight",
    "method": "OPTIONS",
    "body": {},
    "expected": {
      "statusCode": 200
    }
  },
  "get_pathogens": {
    "name": "GET returns available pathogens",
    "method": "GET",
    "body": {},
    "expected": {
      "statusCode": 200,
      "body": {
        "pathogens": [
          "E. coli (чувств.)",
          "E. coli (ESBL)",
          "K. pneumoniae (ESBL)",
          "P. aeruginosa (чувств.)",
          "P. aeruginosa (MDR)",
          "S. aureus (MRSA)",
          "S. aureus (MSSA)"
        ]
      }
    }
  },
  "post_ecoli_sensitive": {
    "name": "POST E. coli sensitive",
    "method": "POST",
    "body": {
      "pathogen": "E. coli (чувств.)",
      "allergy": "нет"
    },
    "expected": {
      "statusCode": 200,
      "body": {
        "type": "targeted",
        "pathogen": "E. coli (чувств.)",
        "risk_group": "low_risk"
      }
    }
  },
  "post_ecoli_esbl": {
    "name": "POST E. coli ESBL - ceftriaxone resistant",
